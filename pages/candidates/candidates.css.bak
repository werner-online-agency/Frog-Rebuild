/* ========================================
   Candidates — Frogg Recruitment
   Homepage-Style Redesign
   ======================================== */

/* ================================================================
   DESIGN TOKENS (matching index.html)
   ================================================================ */
:root {
    --primary-50: #eff6ff;
    --primary-100: #dbeafe;
    --primary-400: #60a5fa;
    --primary-500: #1662ed;
    --primary-600: #1451c7;
    --primary-700: #1e3a8a;
    --primary-900: #0f1e52;
    --accent-400: #818cf8;
    --accent-500: #6366f1;
    --ink-900: #0b1534;
    --ink-800: #101d42;
    --ink-700: #162350;
    --gray-50: #f8fafc;
    --gray-100: #eef2f7;
    --gray-200: #dce5f3;
    --gray-300: #c4d1e5;
    --gray-400: #94a3b8;
    --gray-500: #64748b;
    --gray-600: #4b5563;
    --gray-800: #1f2937;
    --gray-900: #0f172a;
    --gray-950: #030712;
    --white: #ffffff;
    --radius-sm: 0.375rem;
    --radius-md: 12px;
    --radius-lg: 0.75rem;
    --radius-xl: 1rem;
    --radius-2xl: 24px;
    --radius-full: 9999px;
    --shadow-sm: 0 1px 3px rgba(15, 23, 42, 0.06);
    --shadow-md: 0 4px 14px rgba(15, 23, 42, 0.08);
    --shadow-lg: 0 12px 36px rgba(15, 23, 42, 0.12);
    --shadow-xl: 0 24px 56px rgba(15, 23, 42, 0.14);
    --shadow-blue: 0 12px 28px rgba(22, 98, 237, 0.22);
    --shadow-glow: 0 0 60px rgba(22, 98, 237, 0.15);
    --gradient-primary: linear-gradient(135deg, #1662ed 0%, #1e3a8a 100%);
    --gradient-accent: linear-gradient(135deg, var(--primary-400) 0%, var(--accent-500) 100%);
    --gradient-hero: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
    --gradient-dark: linear-gradient(160deg, #0b1534 0%, #101d42 40%, #162350 100%);
    --max-width: 1240px;
    --transition-fast: 150ms ease;
    --transition-base: 300ms ease;
    --transition-bounce: 500ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

*, *::before, *::after { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }

body {
    font-family: "Inter", sans-serif;
    color: var(--gray-800);
    background: var(--white);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

.container {
    width: min(var(--max-width), calc(100% - 2rem));
    margin-inline: auto;
}

/* ================================================================
   KEYFRAME ANIMATIONS
   ================================================================ */
@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(32px); }
    to   { opacity: 1; transform: translateY(0); }
}
@keyframes slideUp {
    from { opacity: 0; transform: translateY(48px); }
    to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
}
@keyframes kenBurns {
    0%   { transform: scale(1) translate(0, 0); }
    50%  { transform: scale(1.12) translate(-1%, -1%); }
    100% { transform: scale(1) translate(0, 0); }
}
@keyframes scrollPulse {
    0%, 100% { height: 12px; opacity: 1; }
    50%      { height: 24px; opacity: 0.4; }
}
@keyframes shimmerBorder {
    0%   { background-position: -200% 0; }
    100% { background-position: 200% 0; }
}
@keyframes dotPulse {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50%      { transform: scale(1.8); opacity: 0; }
}
@keyframes floatOrb {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25%      { transform: translate(20px, -30px) scale(1.05); }
    50%      { transform: translate(-15px, -50px) scale(0.95); }
    75%      { transform: translate(25px, -20px) scale(1.02); }
}

/* ================================================================
   SCROLL REVEAL SYSTEM
   ================================================================ */
.reveal-section {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}
.reveal-section.revealed {
    opacity: 1;
    transform: translateY(0);
}
.revealed .why-card,
.revealed .benefit-item,
.revealed .article-card,
.revealed .process-step {
    opacity: 0;
    transform: translateY(24px);
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
.revealed .why-card[data-delay="0"],
.revealed .benefit-item[data-delay="0"],
.revealed .article-card[data-delay="0"] { animation-delay: 0.05s; }
.revealed .why-card[data-delay="1"],
.revealed .benefit-item[data-delay="1"],
.revealed .article-card[data-delay="1"] { animation-delay: 0.12s; }
.revealed .why-card[data-delay="2"],
.revealed .benefit-item[data-delay="2"],
.revealed .article-card[data-delay="2"] { animation-delay: 0.19s; }
.revealed .why-card[data-delay="3"],
.revealed .benefit-item[data-delay="3"] { animation-delay: 0.26s; }
.revealed .why-card[data-delay="4"],
.revealed .benefit-item[data-delay="4"] { animation-delay: 0.33s; }
.revealed .why-card[data-delay="5"],
.revealed .benefit-item[data-delay="5"] { animation-delay: 0.40s; }
.revealed .process-step[data-step="1"] { animation-delay: 0.1s; }
.revealed .process-step[data-step="2"] { animation-delay: 0.25s; }
.revealed .process-step[data-step="3"] { animation-delay: 0.4s; }
.revealed .process-step[data-step="4"] { animation-delay: 0.55s; }

/* ================================================================
   TRANSPARENT HEADER (Homepage Pattern)
   ================================================================ */
.frogg-header,
.frogg-header *:not(.elementor-nav-menu--dropdown) {
    overflow: visible !important;
}

.frogg-header.header-transparent:not(.scrolled) {
    background: transparent !important;
    box-shadow: none !important;
    backdrop-filter: none;
}
.frogg-header.header-transparent:not(.scrolled) .wdt-nav-menu .elementor-nav-menu--main > li > a,
.frogg-header.header-transparent:not(.scrolled) .wdt-nav-menu .elementor-nav-menu--main > li > span.elementor-item--nolink {
    color: #ffffff !important;
}
.frogg-header.header-transparent:not(.scrolled) .wdt-nav-menu .elementor-nav-menu--main > li > a:hover,
.frogg-header.header-transparent:not(.scrolled) .wdt-nav-menu .elementor-nav-menu--main > li:hover > span.elementor-item--nolink {
    color: #ffffff !important;
}
.frogg-header.header-transparent:not(.scrolled) .wdt-nav-menu .elementor-nav-menu--dropdown a {
    color: #1f2937 !important;
}
.frogg-header.header-transparent:not(.scrolled) .wdt-nav-menu .elementor-nav-menu--dropdown a:hover {
    color: #ffffff !important;
}
.frogg-header.header-transparent:not(.scrolled) .wdt-nav-menu .elementor-nav-menu > li.menu-item-has-children > a::after,
.frogg-header.header-transparent:not(.scrolled) .wdt-nav-menu .elementor-nav-menu > li.menu-item-has-children > span.elementor-item--nolink::after {
    color: rgba(255,255,255,0.7) !important;
}
.frogg-header.header-transparent:not(.scrolled) .wdt-nav-menu .elementor-nav-menu > li.menu-item-has-children:hover > a::after,
.frogg-header.header-transparent:not(.scrolled) .wdt-nav-menu .elementor-nav-menu > li.menu-item-has-children:hover > span.elementor-item--nolink::after {
    color: #ffffff !important;
}
.frogg-header.header-transparent:not(.scrolled) .brand img {
    filter: brightness(0) invert(1) !important;
}
.frogg-header.header-transparent.scrolled .brand img {
    filter: none !important;
}
.frogg-header.header-transparent:not(.scrolled) .frogg-btn-outline .elementor-button {
    border-color: rgba(255,255,255,0.5) !important;
    color: #ffffff !important;
}
.frogg-header.header-transparent:not(.scrolled) .frogg-btn-outline .elementor-button:hover {
    border-color: #ffffff !important;
    background: rgba(255,255,255,0.1) !important;
}
.frogg-header.header-transparent:not(.scrolled) .wdt-toggle-line {
    background: #ffffff;
}
.frogg-header.header-transparent {
    transition: background 0.4s ease, box-shadow 0.4s ease, backdrop-filter 0.4s ease !important;
}

/* Dropdown overrides */
.wdt-nav-menu .elementor-nav-menu--dropdown {
    display: block !important;
    position: absolute !important;
    top: calc(100% + 10px) !important;
    left: 0 !important;
    min-width: 260px !important;
    list-style: none !important;
    margin: 0 !important;
    padding: 10px !important;
    opacity: 0 !important;
    visibility: hidden !important;
    transform: translateY(8px) !important;
    transition: 0.25s ease !important;
    background: #ffffff !important;
    border: 1px solid rgba(18, 104, 251, 0.18) !important;
    border-radius: 16px !important;
    box-shadow: 0 10px 40px rgba(0,0,0,0.1) !important;
    backdrop-filter: blur(10px) !important;
    z-index: 100000 !important;
    pointer-events: auto !important;
}
.wdt-nav-menu .menu-item-has-children:hover > .elementor-nav-menu--dropdown,
.wdt-nav-menu .menu-item-has-children:focus-within > .elementor-nav-menu--dropdown {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
}
.wdt-nav-menu .elementor-nav-menu--dropdown li {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
}
.wdt-nav-menu .elementor-nav-menu--dropdown a {
    display: block !important;
    padding: 9px 22px !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    color: #1f2937 !important;
    border-radius: 11px !important;
    text-decoration: none !important;
    position: relative !important;
    z-index: 1 !important;
    background: none !important;
    background-image: none !important;
    background-color: transparent !important;
}
.wdt-nav-menu .elementor-nav-menu--dropdown a::before {
    content: '' !important;
    position: absolute !important;
    inset: 0 !important;
    background-image: linear-gradient(135deg, rgb(2, 3, 129) 0%, rgb(40, 116, 252) 100%) !important;
    border-radius: 11px !important;
    z-index: -1 !important;
    opacity: 0 !important;
    transition: opacity 0.3s ease !important;
}
.wdt-nav-menu .elementor-nav-menu--dropdown a:hover::before {
    opacity: 1 !important;
}
.wdt-nav-menu .elementor-nav-menu--dropdown a:hover {
    color: #ffffff !important;
}
.wdt-nav-menu .elementor-nav-menu--dropdown::after {
    content: '' !important;
    position: absolute !important;
    top: -12px !important;
    left: 0 !important;
    right: 0 !important;
    height: 12px !important;
}
.wdt-nav-menu .elementor-nav-menu > li {
    position: relative !important;
}

/* ================================================================
   TOPBAR & HEADER OVERRIDES
   ================================================================ */
.wdt-topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100000;
    background: #031543;
    border-bottom: 1px solid rgba(255, 255, 255, 0.09);
}
.topbar-inner {
    width: min(var(--max-width), calc(100% - 2rem));
    min-height: 42px;
    margin-inline: auto;
    display: flex;
    align-items: center;
}
.wdt-topbar-contact { width: 100%; justify-content: space-between; }
.wdt-topbar-contact-item { color: #d7e3ff; font-size: 13px; text-decoration: none; }
.header-inner {
    width: min(var(--max-width), calc(100% - 2rem));
    margin-inline: auto;
    min-height: 84px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
}
.brand img { height: 44px; width: auto; }
.wdt-nav-menu .elementor-nav-menu { margin: 0; padding: 0; list-style: none; }
.wdt-nav-menu .elementor-nav-menu > li { position: relative; }
.header-actions { display: flex; align-items: center; gap: 12px; }
.header-actions .elementor-button { display: inline-flex; align-items: center; justify-content: center; }

/* ================================================================
   HERO — FULL-WIDTH SLIDESHOW (Homepage Pattern)
   ================================================================ */
.hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

/* Slideshow background */
.hero-slideshow {
    position: absolute;
    inset: 0;
    z-index: 0;
}
.hero-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1.2s ease;
    will-change: opacity, transform;
    animation: kenBurns 20s ease-in-out infinite;
}
.hero-slide--active {
    opacity: 1;
}

/* Dark overlay */
.hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom,
        rgba(10, 20, 50, 0.75) 0%,
        rgba(10, 20, 50, 0.85) 50%,
        rgba(10, 20, 50, 0.92) 100%
    );
    z-index: 1;
}

/* Grid overlay (homepage pattern) */
.hero-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
        linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
    background-size: 60px 60px;
    z-index: 2;
    pointer-events: none;
}

.hero-container {
    position: relative;
    z-index: 3;
    padding: 160px 0 100px;
    text-align: center;
}

.hero-content {
    max-width: 780px;
    margin: 0 auto;
}

/* Hero Badge (Glassmorphism — Homepage Pattern) */
.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 22px;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 28px;
}
.hero-badge svg {
    color: #f59e0b;
    flex-shrink: 0;
}

/* Hero Title */
.hero-title {
    margin: 0 0 24px;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    line-height: 1.08;
    color: var(--white);
    letter-spacing: -0.03em;
    font-weight: 800;
}
.gradient-text {
    background: linear-gradient(135deg, #60a5fa, #a78bfa, #60a5fa);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

/* Hero Tagline (Homepage Pattern — quote decorators) */
.hero-tagline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-bottom: 36px;
}
.tagline-decorator {
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3));
    border-radius: 1px;
}
.tagline-decorator:last-child {
    background: linear-gradient(90deg, rgba(255,255,255,0.3), transparent);
}
.hero-tagline p {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.1rem;
    line-height: 1.6;
}
.tagline-quote {
    color: rgba(96, 165, 250, 0.5);
    font-size: 0.85rem;
    margin: 0 4px;
}
.emphasis {
    color: var(--white);
    font-weight: 700;
}

/* Hero CTA Buttons */
.hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    margin-bottom: 36px;
}
.btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 32px;
    border-radius: var(--radius-full);
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s, background 0.25s, border-color 0.25s;
}
.btn-hero .btn-arrow { transition: transform 0.25s; }
.btn-hero:hover .btn-arrow { transform: translateX(4px); }
.btn-hero--primary {
    background: var(--white);
    color: var(--primary-700);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.2);
}
.btn-hero--primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.28);
}
.btn-hero--outline {
    background: transparent;
    color: var(--white);
    border: 2px solid rgba(255, 255, 255, 0.3);
}
.btn-hero--outline:hover {
    border-color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-3px);
}

/* Hero Trust Row */
.hero-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
}
.trust-avatars { display: flex; }
.trust-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--white);
    border: 2px solid rgba(10, 20, 50, 0.6);
    margin-left: -8px;
}
.trust-avatar:first-child { margin-left: 0; }
.trust-label {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
}
.trust-label strong { color: var(--white); }

/* Scroll Indicator */
.hero-scroll-indicator {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 3;
}
.scroll-text {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 600;
}
.scroll-line {
    width: 2px;
    height: 12px;
    background: rgba(255,255,255,.4);
    border-radius: 1px;
    animation: scrollPulse 2.5s ease-in-out infinite;
}

/* Hero Animations */
.animate-fade-in {
    opacity: 0;
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
}
.animate-slide-up {
    opacity: 0;
    animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.35s forwards;
}
.animate-slide-up-delay {
    opacity: 0;
    animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
}
.animate-fade-in-delay {
    opacity: 0;
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.65s forwards;
}
.animate-fade-in-delay-2 {
    opacity: 0;
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.8s forwards;
}

/* ================================================================
   STATS BAR (Glassmorphism — Homepage Pattern)
   ================================================================ */
.stats-bar-section {
    position: relative;
    margin-top: -60px;
    z-index: 10;
    padding-bottom: 20px;
}
.stats-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    background: var(--white);
    border-radius: var(--radius-2xl);
    padding: 28px 40px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12);
    border: 1px solid var(--gray-200);
}
.stats-bar-item {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    justify-content: center;
}
.stats-bar-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    background: var(--primary-50);
    color: var(--primary-500);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.stats-bar-icon--accent {
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
}
.stats-bar-item strong {
    display: block;
    font-size: 1.5rem;
    color: var(--primary-700);
    letter-spacing: -0.02em;
    line-height: 1.1;
}
.stats-bar-item span {
    font-size: 0.78rem;
    color: var(--gray-500);
    line-height: 1.3;
}
.stats-bar-divider {
    width: 1px;
    height: 40px;
    background: var(--gray-200);
    flex-shrink: 0;
    margin: 0 8px;
}

/* ================================================================
   BUTTONS — GENERAL
   ================================================================ */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: var(--radius-md);
    border: 0;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    padding: 14px 28px;
    cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s, background 0.25s;
}
.btn .btn-arrow { transition: transform 0.25s; }
.btn:hover .btn-arrow { transform: translateX(4px); }
.btn-primary {
    background: var(--gradient-primary);
    color: var(--white);
    box-shadow: var(--shadow-blue);
}
.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px rgba(22, 98, 237, 0.32);
}
.btn-outline {
    background: var(--white);
    color: var(--primary-500);
    border: 2px solid var(--primary-100);
}
.btn-outline:hover {
    border-color: var(--primary-500);
    transform: translateY(-2px);
}

/* ================================================================
   SECTION TAG (replaces .eyebrow)
   ================================================================ */
.section-tag {
    display: inline-flex;
    align-items: center;
    padding: 6px 16px;
    border-radius: 999px;
    background: var(--primary-50);
    color: var(--primary-700);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}
.section-tag--dark {
    background: rgba(22, 98, 237, 0.12);
    color: #93bbff;
}

/* Section Headers */
.section-header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 56px;
}
.section-header h2 {
    margin: 14px 0 12px;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    color: var(--ink-900);
    letter-spacing: -0.02em;
}
.section-header p {
    margin: 0;
    color: var(--gray-600);
    font-size: 1.05rem;
    line-height: 1.7;
}
.section-header--light h2 { color: var(--white); }
.section-header--light p { color: rgba(255, 255, 255, 0.65); }

/* ================================================================
   SECTION 2 — WHY USE AGENCY (Light)
   ================================================================ */
.why-section {
    padding: 100px 0;
    background: var(--white);
}
.why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
.why-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-xl);
    padding: 32px 28px;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.3s, transform 0.3s, border-color 0.3s;
    position: relative;
    overflow: hidden;
}
.why-card .card-glow {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, #1662ed, #a78bfa, #1662ed, transparent);
    background-size: 300% 100%;
    opacity: 0;
    transition: opacity 0.3s;
}
.why-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-6px);
    border-color: var(--primary-100);
}
.why-card:hover .card-glow {
    opacity: 1;
    animation: shimmerBorder 3s linear infinite;
}
.why-card--highlight {
    background: var(--primary-50);
    border-color: var(--primary-100);
}
.why-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    color: var(--primary-500);
    margin-bottom: 18px;
    transition: background var(--transition-base), color var(--transition-base), transform var(--transition-base);
}
.why-card--highlight .why-icon {
    background: var(--white);
}
.why-card:hover .why-icon {
    background: var(--primary-500);
    color: var(--white);
    transform: scale(1.1) rotate(-5deg);
}
.why-card h3 {
    margin: 0 0 8px;
    font-size: 1.08rem;
    color: var(--ink-900);
}
.why-card p {
    margin: 0;
    font-size: 0.92rem;
    color: var(--gray-600);
    line-height: 1.65;
}
.why-card a {
    color: var(--primary-500);
    text-decoration: none;
    font-weight: 600;
}
.why-card a:hover { text-decoration: underline; }

/* ================================================================
   SECTION 3 — PROCESS TIMELINE (Dark)
   ================================================================ */
.process-section {
    position: relative;
    padding: 100px 0;
    overflow: hidden;
}
.process-bg {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(to bottom, rgba(10,20,50,.92), rgba(10,20,50,.96)),
        url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
    z-index: -2;
}
.process-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse 50% 50% at 15% 20%, rgba(22, 98, 237, 0.1), transparent),
        radial-gradient(ellipse 40% 40% at 85% 80%, rgba(30, 58, 138, 0.08), transparent);
}
.process-timeline {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    max-width: 1100px;
    margin: 0 auto;
}
.process-step {
    text-align: center;
    position: relative;
}
.step-marker {
    display: flex;
    justify-content: center;
    margin-bottom: 24px;
}
.step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(22, 98, 237, 0.15);
    border: 2px solid rgba(22, 98, 237, 0.3);
    color: #93bbff;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
}
.process-step:hover .step-num {
    background: rgba(22, 98, 237, 0.25);
    border-color: var(--primary-500);
    transform: scale(1.1);
}
.process-step:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 26px;
    left: calc(50% + 34px);
    width: calc(100% - 68px);
    height: 2px;
    background: linear-gradient(90deg, rgba(22,98,237,.3), rgba(22,98,237,.1));
    z-index: 0;
}
.step-content {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-xl);
    padding: 28px 24px;
    backdrop-filter: blur(8px);
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
}
.process-step:hover .step-content {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(22, 98, 237, 0.25);
    transform: translateY(-4px);
}
.step-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    background: rgba(22, 98, 237, 0.12);
    color: #93bbff;
    margin-bottom: 16px;
    transition: background 0.3s, transform 0.3s;
}
.process-step:hover .step-icon {
    background: rgba(22, 98, 237, 0.2);
    transform: scale(1.08) rotate(-3deg);
}
.step-content h3 {
    margin: 0 0 10px;
    font-size: 1.05rem;
    color: var(--white);
    font-weight: 700;
}
.step-content p {
    margin: 0;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.65;
}
.process-cta {
    text-align: center;
    margin-top: 48px;
}

/* ================================================================
   SECTION 4 — BENEFITS (Dark)
   ================================================================ */
.benefits-section {
    position: relative;
    padding: 100px 0;
    overflow: hidden;
}
.benefits-bg {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(to bottom, rgba(10,20,50,.90), rgba(10,20,50,.94)),
        url('https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
    z-index: -2;
}
.benefits-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse 50% 50% at 85% 15%, rgba(22, 98, 237, 0.12), transparent),
        radial-gradient(ellipse 40% 50% at 5% 90%, rgba(30, 58, 138, 0.1), transparent);
}
.benefits-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 18px;
    max-width: 1100px;
    margin: 0 auto;
}
.benefit-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    padding: 24px;
    backdrop-filter: blur(4px);
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
}
.benefit-item:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(22, 98, 237, 0.3);
    transform: translateY(-4px);
}
.benefit-item--highlight {
    background: rgba(22, 98, 237, 0.1);
    border-color: rgba(22, 98, 237, 0.25);
}
.benefit-item--highlight:hover {
    background: rgba(22, 98, 237, 0.16);
}
.benefit-num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: rgba(22, 98, 237, 0.15);
    color: #93bbff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    margin-top: 1px;
    transition: background 0.3s, transform 0.3s;
}
.benefit-item:hover .benefit-num {
    background: rgba(22, 98, 237, 0.25);
    transform: scale(1.08);
}
.benefit-item h4 {
    margin: 0 0 6px;
    font-size: 0.95rem;
    color: var(--white);
    font-weight: 700;
}
.benefit-item p {
    margin: 0;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
}
.benefit-item a {
    color: #93bbff;
    text-decoration: none;
    font-weight: 600;
}
.benefit-item a:hover { text-decoration: underline; }

/* ================================================================
   SECTION 5 — CAREER PLANNING (Light)
   ================================================================ */
.career-section {
    padding: 100px 0;
    background: var(--gray-50);
}
.career-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
}
.career-content h2 {
    margin: 14px 0 20px;
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    color: var(--ink-900);
    line-height: 1.2;
}
.career-content > p {
    margin: 0 0 20px;
    color: var(--gray-800);
    line-height: 1.75;
    font-size: 1.02rem;
}
.career-checklist {
    list-style: none;
    margin: 0 0 8px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
}
.career-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
    color: var(--gray-800);
    line-height: 1.5;
}
.check-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--primary-50);
    color: var(--primary-500);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
}
.career-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
}
.career-image { position: relative; }
.career-img-wrapper {
    position: relative;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    border: 1px solid var(--gray-200);
}
.career-img-wrapper img {
    width: 100%;
    height: 460px;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}
.career-img-wrapper:hover img { transform: scale(1.04); }
.career-img-badge {
    position: absolute;
    bottom: 20px;
    left: 20px;
    background: rgba(255,255,255,.95);
    backdrop-filter: blur(10px);
    border-radius: var(--radius-full);
    padding: 10px 18px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--primary-700);
    box-shadow: 0 8px 24px rgba(0,0,0,.12);
    border: 1px solid rgba(22,98,237,.1);
}
.career-img-badge svg { color: #f59e0b; }

/* ================================================================
   SECTION 6 — BEYOND (Dark)
   ================================================================ */
.beyond-section {
    position: relative;
    padding: 100px 0;
    overflow: hidden;
}
.beyond-bg {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(to bottom, rgba(10,20,50,.90), rgba(10,20,50,.94)),
        url('https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
    z-index: -2;
}
.beyond-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse 55% 55% at 20% 30%, rgba(22, 98, 237, 0.14), transparent),
        radial-gradient(ellipse 40% 40% at 90% 80%, rgba(30, 58, 138, 0.1), transparent);
}
.beyond-orbs {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
}
.beyond-orb {
    position: absolute;
    border-radius: 50%;
}
.beyond-orb--1 {
    width: 300px;
    height: 300px;
    top: -60px;
    right: 10%;
    background: radial-gradient(circle, rgba(22, 98, 237, 0.08), transparent 70%);
    animation: floatOrb 20s ease-in-out infinite;
}
.beyond-orb--2 {
    width: 200px;
    height: 200px;
    bottom: -40px;
    left: 5%;
    background: radial-gradient(circle, rgba(30, 58, 138, 0.06), transparent 70%);
    animation: floatOrb 25s ease-in-out infinite reverse;
}
.beyond-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 56px;
    align-items: center;
}
.beyond-copy h2 {
    margin: 14px 0 20px;
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    color: var(--white);
    line-height: 1.2;
}
.beyond-copy > p {
    margin: 0 0 16px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.75;
    font-size: 1.02rem;
}
.beyond-copy .btn-hero { margin-top: 12px; }
.beyond-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
}
.stat-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-xl);
    padding: 32px 24px;
    text-align: center;
    backdrop-filter: blur(4px);
    transition: background 0.3s, transform 0.3s, border-color 0.3s;
}
.stat-card:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-4px);
    border-color: rgba(22, 98, 237, 0.3);
}
.stat-card--accent {
    background: rgba(22, 98, 237, 0.08);
    border-color: rgba(22, 98, 237, 0.15);
}
.stat-card--accent:hover {
    background: rgba(22, 98, 237, 0.14);
}
.stat-card strong {
    display: block;
    font-size: 2.2rem;
    color: var(--white);
    letter-spacing: -0.02em;
    margin-bottom: 6px;
}
.stat-card span {
    font-size: 0.86rem;
    color: rgba(255, 255, 255, 0.55);
}

/* ================================================================
   CTA BANNER — Dual Cards
   ================================================================ */
.cta-banner {
    padding: 60px 0;
}
.cta-banner-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 960px;
    margin: 0 auto;
    gap: 24px;
}
.cta-col {
    background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: var(--radius-xl);
    padding: 40px 32px;
    text-align: center;
    transition: transform .3s, box-shadow .3s, background .4s, border-color .4s;
}
.cta-col:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0,0,0,.18);
    background: #ffffff;
    border-color: var(--gray-200);
}
.cta-col-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(255,255,255,.08);
    color: #93bbff;
    margin-bottom: 18px;
    transition: background var(--transition-base), color var(--transition-base);
}
.cta-col:hover .cta-col-icon {
    background: var(--primary-50);
    color: var(--primary-500);
}
.cta-col h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 12px;
    transition: color .4s;
}
.cta-col:hover h3 { color: var(--gray-900); }
.cta-col p {
    font-size: .92rem;
    color: rgba(255,255,255,.7);
    line-height: 1.6;
    margin: 0 0 24px;
    transition: color .4s;
}
.cta-col:hover p { color: var(--gray-500); }
.cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    color: #1e3a8a;
    padding: 12px 28px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: .95rem;
    transition: transform .2s, box-shadow .2s, background .3s, color .3s;
}
.cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(22,98,237,.35);
}
.cta-col:hover .cta-btn {
    background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
    color: #fff;
}
.cta-btn .btn-arrow { transition: transform .2s; }
.cta-btn:hover .btn-arrow { transform: translateX(4px); }

/* ================================================================
   SECTION 7 — ARTICLES (Light)
   ================================================================ */
.articles-section {
    padding: 100px 0;
    background: var(--gray-50);
}
.articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
.article-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.3s, transform 0.3s, border-color 0.3s;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
}
.article-card-img {
    width: 100%;
    overflow: hidden;
    position: relative;
}
.article-card-img img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    transition: transform .5s cubic-bezier(0.16, 1, 0.3, 1);
}
.article-card:hover .article-card-img img { transform: scale(1.06); }
.article-tag {
    position: absolute;
    top: 14px;
    left: 14px;
    padding: 5px 12px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(8px);
    color: var(--primary-700);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid rgba(22,98,237,.1);
    transition: background 0.3s, color 0.3s;
}
.article-card:hover .article-tag {
    background: var(--gradient-primary);
    color: var(--white);
    border-color: transparent;
}
.article-card-body {
    padding: 24px 28px 28px;
    display: flex;
    flex-direction: column;
    flex: 1;
}
.article-meta {
    font-size: 0.75rem;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    margin-bottom: 10px;
}
.article-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, #1662ed, #a78bfa, #1662ed, transparent);
    background-size: 300% 100%;
    opacity: 0;
    transition: opacity 0.3s;
}
.article-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-6px);
    border-color: var(--primary-100);
}
.article-card:hover::after {
    opacity: 1;
    animation: shimmerBorder 3s linear infinite;
}
.article-card h3 {
    margin: 0 0 10px;
    font-size: 1.1rem;
    color: var(--ink-900);
    line-height: 1.3;
}
.article-card p {
    margin: 0 0 16px;
    font-size: 0.92rem;
    color: var(--gray-600);
    line-height: 1.65;
    flex: 1;
}
.article-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--primary-500);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: gap var(--transition-fast);
}
.article-link:hover { gap: 10px; }
.articles-more {
    text-align: center;
    margin-top: 40px;
}

/* ================================================================
   SECTION 8 — TESTIMONIALS CAROUSEL
   ================================================================ */
.testimonials-section {
    padding: 100px 0;
    background: var(--white);
}
.testimonial-carousel {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-2xl);
}
.testimonial-track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}
.testimonial-slide {
    flex: 0 0 100%;
    padding: 0 8px;
}
.testimonial-card {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-xl);
    padding: 40px 40px 36px;
    max-width: 680px;
    margin: 0 auto;
    position: relative;
}
.testimonial-card::before {
    content: '\201C';
    position: absolute;
    top: 20px;
    right: 32px;
    font-size: 5rem;
    color: var(--primary-50);
    font-family: Georgia, serif;
    line-height: 1;
    pointer-events: none;
}
.testimonial-stars {
    display: flex;
    gap: 3px;
    color: #f59e0b;
    margin-bottom: 18px;
}
.testimonial-card blockquote {
    margin: 0 0 24px;
    padding: 0;
    font-size: 1.08rem;
    color: var(--gray-800);
    line-height: 1.75;
    font-style: italic;
}
.testimonial-author {
    display: flex;
    align-items: center;
    gap: 14px;
}
.author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
}
.testimonial-author strong {
    display: block;
    font-size: 0.95rem;
    color: var(--ink-900);
}
.testimonial-author span {
    font-size: 0.82rem;
    color: var(--gray-500);
}
.carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 28px;
}
.carousel-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--gray-200);
    background: var(--white);
    color: var(--gray-600);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
}
.carousel-btn:hover {
    background: var(--primary-500);
    color: var(--white);
    border-color: var(--primary-500);
    transform: scale(1.08);
}
.carousel-dots {
    display: flex;
    gap: 8px;
}
.carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gray-200);
    border: none;
    cursor: pointer;
    transition: background var(--transition-fast), width var(--transition-base), border-radius var(--transition-base);
}
.carousel-dot.active {
    width: 28px;
    border-radius: 5px;
    background: var(--primary-500);
}

/* ================================================================
   SECTION 9 — CONTACT (Dark)
   ================================================================ */
.contact-section {
    padding: 100px 0;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
}
.contact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
}
.contact-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-xl);
    padding: 32px 24px 28px;
    box-shadow: var(--shadow-sm);
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.3s, transform 0.3s;
    text-align: center;
}
.contact-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-6px);
}
.contact-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--primary-50);
    color: var(--primary-500);
    margin-bottom: 18px;
    transition: background var(--transition-base), color var(--transition-base), transform var(--transition-base);
}
.contact-card:hover .contact-card-icon {
    background: var(--primary-500);
    color: var(--white);
    transform: scale(1.1) rotate(-5deg);
}
.contact-card h3 { margin: 0 0 14px; font-size: 0.95rem; color: var(--ink-900); line-height: 1.4; }
.contact-card p { margin: 0 0 4px; font-size: 0.9rem; color: var(--gray-600); line-height: 1.5; }
.contact-card a { color: var(--primary-500); text-decoration: none; font-weight: 600; }
.contact-card a:hover { text-decoration: underline; }
.contact-section .section-header h2 { color: #fff; }
.contact-section .section-header p { color: rgba(255,255,255,.7); }

/* ================================================================
   RESPONSIVE
   ================================================================ */
@media (max-width: 1100px) {
    .wdt-topbar { display: none; }
    .frogg-header { top: 0; }
    .header-actions { display: none; }
    .wdt-nav-menu { display: none !important; }
    .wdt-mobile-toggle { display: flex !important; }

    .hero-section { min-height: 80vh; }
    .hero-container { padding: 140px 0 80px; }

    .stats-bar { flex-wrap: wrap; gap: 20px; padding: 24px 28px; }
    .stats-bar-divider { display: none; }
    .stats-bar-item { min-width: 45%; }

    .why-section,
    .benefits-section,
    .career-section,
    .beyond-section,
    .process-section,
    .articles-section,
    .testimonials-section { padding: 72px 0; }
    .contact-section { padding: 72px 0; }

    .why-grid { grid-template-columns: 1fr 1fr; }
    .process-timeline { grid-template-columns: 1fr 1fr; }
    .process-step:not(:last-child)::after { display: none; }
    .benefits-grid { grid-template-columns: 1fr 1fr; }
    .career-grid { grid-template-columns: 1fr; }
    .beyond-grid { grid-template-columns: 1fr; }
    .articles-grid { grid-template-columns: 1fr 1fr; }
    .contact-grid { grid-template-columns: 1fr 1fr; }
    .cta-banner-grid { max-width: 100%; }
}

@media (max-width: 767px) {
    .header-inner { min-height: 74px; }
    .brand img { height: 36px; }

    .hero-section { min-height: 90vh; }
    .hero-container { padding: 120px 0 80px; }
    .hero-title { font-size: clamp(1.8rem, 7vw, 2.6rem); }
    .hero-tagline { flex-direction: column; gap: 8px; }
    .hero-tagline .tagline-decorator { width: 30px; }
    .hero-cta { flex-direction: column; align-items: center; }
    .btn-hero { width: 100%; max-width: 320px; justify-content: center; }

    .stats-bar-section { margin-top: -40px; }
    .stats-bar { flex-direction: column; gap: 18px; padding: 24px 20px; }
    .stats-bar-item { min-width: 100%; justify-content: flex-start; }

    .why-section,
    .benefits-section,
    .career-section,
    .beyond-section,
    .process-section,
    .articles-section,
    .testimonials-section { padding: 56px 0; }
    .contact-section { padding: 56px 0; }

    .why-grid { grid-template-columns: 1fr; }
    .process-timeline { grid-template-columns: 1fr; }
    .benefits-grid { grid-template-columns: 1fr; }
    .career-img-wrapper img { height: 280px; }
    .beyond-stats { grid-template-columns: 1fr 1fr; }
    .articles-grid { grid-template-columns: 1fr; }
    .contact-grid { grid-template-columns: 1fr; }
    .cta-banner-grid {
        grid-template-columns: 1fr;
    }
    .cta-banner { padding: 40px 0; }
    .cta-col { padding: 28px 24px; }

    .testimonial-card { padding: 28px 24px; }
    .testimonial-card blockquote { font-size: 0.98rem; }

    .section-header { margin-bottom: 40px; }
    .hero-scroll-indicator { display: none; }
    .hero-grid-overlay { display: none; }
}
