{
  "title": "FROGG Header Section",
  "type": "header",
  "version": "0.4",
  "page_settings": {
    "hide_title": true
  },
  "content": [
    {
      "id": "header-section",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "html_tag": "header",
        "flex_direction": "row",
        "flex_justify_content": "center",
        "flex_align_items": "center",
        "padding": { "unit": "px", "top": "16", "right": "0", "bottom": "16", "left": "0", "isLinked": false },
        "position": "fixed",
        "z_index": 200,
        "width": { "unit": "%", "size": 100 },
        "css_classes": "frogg-header",
        "background_background": "classic",
        "background_color": "transparent",
        "_element_custom_css": ".frogg-header.scrolled { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(20px); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); padding-top: 8px !important; padding-bottom: 8px !important; }"
      },
      "elements": [
        {
          "id": "header-inner-container",
          "elType": "container",
          "settings": {
            "content_width": "boxed",
            "boxed_width": { "unit": "px", "size": 1400 },
            "flex_direction": "row",
            "flex_justify_content": "space-between",
            "flex_align_items": "center",
            "flex_gap": { "unit": "px", "size": 20, "column": "20", "row": "20" },
            "padding": { "unit": "px", "top": "0", "right": "32", "bottom": "0", "left": "32", "isLinked": false }
          },
          "elements": [
            {
              "id": "logo-container",
              "elType": "container",
              "settings": {
                "content_width": "full",
                "width": { "unit": "px", "size": 180 },
                "min_width": { "unit": "px", "size": 120 },
                "flex_direction": "row",
                "flex_align_items": "center"
              },
              "elements": [
                {
                  "id": "site-logo",
                  "elType": "widget",
                  "widgetType": "theme-site-logo",
                  "settings": {
                    "image": {
                      "url": "/images/New-logo-300x104.png",
                      "id": ""
                    },
                    "image_size": "full",
                    "align": "left",
                    "width": { "unit": "px", "size": 150 },
                    "max_width": { "unit": "%", "size": 100 },
                    "height": { "unit": "px", "size": 45 },
                    "object_fit": "contain",
                    "link_to": "custom",
                    "link": { "url": "#home", "is_external": false, "nofollow": false },
                    "css_classes": "frogg-logo-img",
                    "css_filters_css_filter": "custom",
                    "css_filters_brightness": { "unit": "%", "size": 0 },
                    "css_filters_invert": { "unit": "%", "size": 100 },
                    "_element_custom_css": ".scrolled .frogg-logo-img img { filter: none !important; }"
                  }
                }
              ]
            },
            {
              "id": "nav-container",
              "elType": "container",
              "settings": {
                "content_width": "full",
                "flex_direction": "row",
                "flex_justify_content": "center",
                "flex_align_items": "center",
                "flex_grow": { "unit": "px", "size": 1 },
                "hide_mobile": "hidden-phone",
                "hide_tablet": "hidden-tablet"
              },
              "elements": [
                {
                  "id": "nav-menu",
                  "elType": "widget",
                  "widgetType": "nav-menu",
                  "settings": {
                    "menu": "main-menu",
                    "layout": "horizontal",
                    "align_items": "center",
                    "submenu_indicator": "none",
                    "pointer": "underline",
                    "animation_line": "fade",
                    "toggle": "none",
                    "dropdown": "none",
                    "text_color": "rgba(255, 255, 255, 0.8)",
                    "color_hover": "#ffffff",
                    "color_active": "#ffffff",
                    "pointer_color": "#1662ed",
                    "pointer_width": { "unit": "px", "size": 2 },
                    "typography_typography": "custom",
                    "typography_font_family": "Inter",
                    "typography_font_size": { "unit": "px", "size": 15 },
                    "typography_font_weight": "500",
                    "space_between": { "unit": "px", "size": 32 },
                    "padding_horizontal": { "unit": "px", "size": 0 },
                    "padding_vertical": { "unit": "px", "size": 8 },
                    "css_classes": "frogg-nav-menu",
                    "_element_custom_css": ".scrolled .frogg-nav-menu .elementor-nav-menu a { color: #4b5563 !important; } .scrolled .frogg-nav-menu .elementor-nav-menu a:hover, .scrolled .frogg-nav-menu .elementor-nav-menu a.current { color: #1662ed !important; }"
                  }
                }
              ]
            },
            {
              "id": "header-actions-container",
              "elType": "container",
              "settings": {
                "content_width": "full",
                "width": { "unit": "px", "size": "auto" },
                "flex_direction": "row",
                "flex_align_items": "center",
                "flex_gap": { "unit": "px", "size": 16, "column": "16", "row": "16" }
              },
              "elements": [
                {
                  "id": "btn-view-vacancies",
                  "elType": "widget",
                  "widgetType": "button",
                  "settings": {
                    "text": "View Vacancies",
                    "link": { "url": "#vacancies", "is_external": false, "nofollow": false },
                    "button_type": "default",
                    "background_color": "transparent",
                    "button_background_hover_color": "rgba(255, 255, 255, 0.1)",
                    "button_text_color": "#ffffff",
                    "hover_color": "#ffffff",
                    "typography_typography": "custom",
                    "typography_font_family": "Inter",
                    "typography_font_size": { "unit": "px", "size": 14 },
                    "typography_font_weight": "600",
                    "border_border": "solid",
                    "border_width": { "unit": "px", "top": "2", "right": "2", "bottom": "2", "left": "2", "isLinked": true },
                    "border_color": "rgba(255, 255, 255, 0.3)",
                    "border_radius": { "unit": "px", "top": "10", "right": "10", "bottom": "10", "left": "10", "isLinked": true },
                    "text_padding": { "unit": "px", "top": "12", "right": "24", "bottom": "12", "left": "24", "isLinked": false },
                    "hover_border_color": "rgba(255, 255, 255, 0.5)",
                    "css_classes": "frogg-btn-outline",
                    "hide_mobile": "hidden-phone",
                    "_element_custom_css": ".scrolled .frogg-btn-outline .elementor-button { border-color: #1662ed !important; color: #1662ed !important; } .scrolled .frogg-btn-outline .elementor-button:hover { background-color: rgba(22, 98, 237, 0.1) !important; }"
                  }
                },
                {
                  "id": "btn-get-started",
                  "elType": "widget",
                  "widgetType": "button",
                  "settings": {
                    "text": "Get Started",
                    "link": { "url": "#contact", "is_external": false, "nofollow": false },
                    "button_type": "default",
                    "background_color": "#1662ed",
                    "button_background_hover_color": "#2649b0",
                    "button_text_color": "#ffffff",
                    "hover_color": "#ffffff",
                    "typography_typography": "custom",
                    "typography_font_family": "Inter",
                    "typography_font_size": { "unit": "px", "size": 14 },
                    "typography_font_weight": "600",
                    "border_radius": { "unit": "px", "top": "10", "right": "10", "bottom": "10", "left": "10", "isLinked": true },
                    "text_padding": { "unit": "px", "top": "12", "right": "24", "bottom": "12", "left": "24", "isLinked": false },
                    "button_box_shadow_box_shadow_type": "yes",
                    "button_box_shadow_box_shadow": { "horizontal": 0, "vertical": 4, "blur": 15, "spread": 0, "color": "rgba(22, 98, 237, 0.3)" },
                    "css_classes": "frogg-btn-primary",
                    "hide_mobile": "hidden-phone"
                  }
                },
                {
                  "id": "mobile-menu-toggle",
                  "elType": "container",
                  "settings": {
                    "content_width": "full",
                    "width": { "unit": "px", "size": 48 },
                    "height": { "unit": "px", "size": 48 },
                    "flex_direction": "column",
                    "flex_justify_content": "center",
                    "flex_align_items": "center",
                    "flex_gap": { "unit": "px", "size": 5 },
                    "padding": { "unit": "px", "top": "8", "right": "8", "bottom": "8", "left": "8", "isLinked": true },
                    "css_classes": "frogg-mobile-toggle",
                    "cursor": "pointer",
                    "hide_desktop": "hidden-desktop"
                  },
                  "elements": [
                    {
                      "id": "toggle-line-1",
                      "elType": "widget",
                      "widgetType": "html",
                      "settings": {
                        "html": "<span class=\"toggle-line\"></span>",
                        "css_classes": "frogg-toggle-line"
                      }
                    },
                    {
                      "id": "toggle-line-2",
                      "elType": "widget",
                      "widgetType": "html",
                      "settings": {
                        "html": "<span class=\"toggle-line\"></span>",
                        "css_classes": "frogg-toggle-line"
                      }
                    },
                    {
                      "id": "toggle-line-3",
                      "elType": "widget",
                      "widgetType": "html",
                      "settings": {
                        "html": "<span class=\"toggle-line\"></span>",
                        "css_classes": "frogg-toggle-line"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "mobile-menu-panel",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "position": "fixed",
        "z_index": 199,
        "width": { "unit": "%", "size": 100 },
        "height": { "unit": "vh", "size": 100 },
        "flex_direction": "column",
        "flex_justify_content": "center",
        "flex_align_items": "center",
        "background_background": "classic",
        "background_color": "#0f172a",
        "padding": { "unit": "px", "top": "80", "right": "24", "bottom": "40", "left": "24", "isLinked": false },
        "css_classes": "frogg-mobile-menu",
        "hide_desktop": "hidden-desktop",
        "_element_custom_css": ".frogg-mobile-menu { display: none; opacity: 0; transform: translateX(100%); transition: all 0.3s ease; } .frogg-mobile-menu.active { display: flex; opacity: 1; transform: translateX(0); }"
      },
      "elements": [
        {
          "id": "mobile-nav-menu",
          "elType": "widget",
          "widgetType": "nav-menu",
          "settings": {
            "menu": "main-menu",
            "layout": "vertical",
            "align_items": "center",
            "submenu_indicator": "none",
            "pointer": "none",
            "toggle": "none",
            "text_color": "#ffffff",
            "color_hover": "#60a5fa",
            "color_active": "#60a5fa",
            "typography_typography": "custom",
            "typography_font_family": "Inter",
            "typography_font_size": { "unit": "px", "size": 24 },
            "typography_font_weight": "600",
            "space_between": { "unit": "px", "size": 24 },
            "margin": { "unit": "px", "top": "0", "right": "0", "bottom": "40", "left": "0", "isLinked": false }
          }
        },
        {
          "id": "mobile-buttons-container",
          "elType": "container",
          "settings": {
            "content_width": "full",
            "flex_direction": "column",
            "flex_align_items": "center",
            "flex_gap": { "unit": "px", "size": 16 }
          },
          "elements": [
            {
              "id": "mobile-btn-vacancies",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "View Vacancies",
                "link": { "url": "#vacancies", "is_external": false, "nofollow": false },
                "button_type": "default",
                "background_color": "transparent",
                "button_text_color": "#ffffff",
                "typography_typography": "custom",
                "typography_font_size": { "unit": "px", "size": 16 },
                "typography_font_weight": "600",
                "border_border": "solid",
                "border_width": { "unit": "px", "top": "2", "right": "2", "bottom": "2", "left": "2", "isLinked": true },
                "border_color": "rgba(255, 255, 255, 0.3)",
                "border_radius": { "unit": "px", "top": "10", "right": "10", "bottom": "10", "left": "10", "isLinked": true },
                "text_padding": { "unit": "px", "top": "14", "right": "48", "bottom": "14", "left": "48", "isLinked": false }
              }
            },
            {
              "id": "mobile-btn-get-started",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Get Started",
                "link": { "url": "#contact", "is_external": false, "nofollow": false },
                "button_type": "default",
                "background_color": "#1662ed",
                "button_text_color": "#ffffff",
                "typography_typography": "custom",
                "typography_font_size": { "unit": "px", "size": 16 },
                "typography_font_weight": "600",
                "border_radius": { "unit": "px", "top": "10", "right": "10", "bottom": "10", "left": "10", "isLinked": true },
                "text_padding": { "unit": "px", "top": "14", "right": "48", "bottom": "14", "left": "48", "isLinked": false }
              }
            }
          ]
        }
      ]
    }
  ]
}
